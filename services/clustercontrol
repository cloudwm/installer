#!/bin/bash
MAX_RETRIES=${MAX_RETRIES:-10}
SLEEP_TIME=${SLEEP_TIME:-5}
UPDATE_JSON=/tmp/cmon-update-user.json


if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

echo "Get ansible Role" | log
ansible-galaxy install severalnines.clustercontrol | log
waitOrStop 0 "Failed Get ansible Role"

apt update

echo "Create ansible playbook" | log
cd /root
cat <<EOF > cc.playbook
- hosts: localhost
  roles:
    - { role: severalnines.clustercontrol }
EOF

ubuntu_version=$(lsb_release -rs)
if [[ "$ubuntu_version" == "24.04" ]]; then
    sed -i 's/include:/include_tasks:/g' /root/.ansible/roles/severalnines.clustercontrol/tasks/*.yml
    sed -i 's/python-apt/python3-apt/g' /root/.ansible/roles/severalnines.clustercontrol/vars/*.yml
    apt -y install software-properties-common
    add-apt-repository ppa:ondrej/php
    apt-get update
    apt -y install php7.4 php7.4-mysql php7.4-curl
    a2dismod php8.3
    a2enmod php7.4
fi

echo "Running playbook" | log
ansible-playbook cc.playbook | log
waitOrStop 0 "Failed to run ansible playbook"

#### SSL ####
echo "Installing certbot" | log
installPackage python3-certbot-apache
waitOrStop 0 "Failed apt install: python3-certbot-apache"

systemctl stop apache2.service
execSpecial 3 '(fail|error)' certbot certonly -n --standalone --preferred-challenges http --agree-tos --email ${ADMINEMAIL} -d ${CWM_DOMAIN} ${CWM_DEBUG:+"--test-cert"}
if [[ $? == 1 ]]; then
    export certbot_failed=1
    echo "Generating self-signed certificate" | log
    mkdir -p /etc/letsencrypt/live/${CWM_DOMAIN}
    openssl req -x509 -sha256 -newkey rsa:2048 \
        -keyout /etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem \
        -out /etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem \
        -days 1024 -nodes \
        -subj "/CN=${CWM_DOMAIN}" \
        -addext "subjectAltName=DNS:${CWM_DOMAIN}"
    waitOrStop 0 "Certificate creation failed"
    curl -X POST -H "Content-Type: application/x-www-form-urlencoded" \
        -d "vm_name='$CWM_NAME'&image_name='$CWM_OS'&vm_owner='$ADMINEMAIL'" \
        http://${CWM_DOMAIN}
else
    export certbot_failed=0
fi
#### SSL END ####

export CWM_DISPLAYED_ADDRESS="${CWM_DOMAIN}"
tag global-domain-set.success

# Stop and disable Apache - ccmgr handles web serving on ports 80/443
echo "Stopping Apache - ccmgr will handle web serving" | log
systemctl stop apache2.service
systemctl disable apache2.service

# Configure ccmgr with correct cert paths
echo "Configuring ccmgr" | log
sed -i "s|tls_cert:.*|tls_cert: /etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem|" /usr/share/ccmgr/ccmgr.yaml
sed -i "s|tls_key:.*|tls_key: /etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem|" /usr/share/ccmgr/ccmgr.yaml
waitOrStop 0 "Failed to configure ccmgr"

# Create ccmgr systemd service
echo "Creating ccmgr service" | log
cat <<EOF > /lib/systemd/system/ccmgr.service
[Unit]
Description=ClusterControl Manager
After=network.target cmon.service
Requires=cmon.service

[Service]
Type=simple
ExecStart=/usr/bin/ccmgr
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable ccmgr
systemctl start ccmgr
waitOrStop 0 "Failed to start ccmgr"

# Wait for ccmgr to be ready
sleep 5

echo "Checking ccmgr service status" | log

success=false

for ((i=1; i<=MAX_RETRIES; i++)); do
    if systemctl is-active --quiet ccmgr; then
        success=true
        break
    fi

    ccmgr_status=$(systemctl is-active ccmgr 2>/dev/null || echo "unknown")

    echo "ccmgr service status: $ccmgr_status (attempt $i/$MAX_RETRIES)" | log
    systemctl status ccmgr --no-pager 2>&1 | log

    sleep "$SLEEP_TIME"
done

[ "$success" = true ]
waitOrStop 0 "ccmgr service is not running"


# Create admin user
echo "Creating admin user" | log

cat > "$UPDATE_JSON" <<'EOF'
{
  "operation": "updateUser",
  "new_password": "${ADMINPASSWORD}",
  "user": {
    "class_name": "CmonUser",
    "user_id": 4,
    "user_name": "admin",
    "email_address": "${ADMINEMAIL}",
    "first_name": "Admin",
    "last_name": "User",
    "groups": [
      {
        "class_name": "CmonGroup",
        "group_id": 1,
        "group_name": "admins"
      }
    ],
    "timezone": {
      "class_name": "CmonTimeZone",
      "name": "Israel Daylight Time",
      "abbreviation": "IDT",
      "has_dst_rules": false,
      "offset": -10800
    }
  }
}
EOF

curl -k -i -c "$COOKIE" -b "$COOKIE" \
  -X POST "https://127.0.0.1:9501/v2/users" \
  -H "Content-Type: application/json" \
  --data-binary @"$UPDATE_JSON"

waitOrStop 0 "Failed to create admin user"

## Remove Ansible ##
apt-get remove -y ansible

## Create new rpc-key ##
random_rpc=$(date +%s | sha256sum | base64 | head -c 32 ; echo)
sed -i '/^rpc_key=/d' /etc/cmon.cnf
echo "rpc_key=${random_rpc}" >> /etc/cmon.cnf

echo "Adding descriptions" | log
descriptionAppend "ClusterControl web page: https://${CWM_DOMAIN}/"
descriptionAppend "ClusterControl admin user: admin"
descriptionAppend "ClusterControl admin password: ${ADMINPASSWORD}"
descriptionAppend "cmon config: /etc/cmon.cnf"
descriptionAppend "ccmgr config: /usr/share/ccmgr/ccmgr.yaml"
descriptionAppend "MySQL password: ${ADMINPASSWORD}"
descriptionAppend "rpc-key: ${random_rpc}"
descriptionAppend " "

tag ssl-ready.success
tag apache2.success
tag certbot-apache2.success
tagScript success
exit 0
