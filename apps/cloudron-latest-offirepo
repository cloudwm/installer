#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

rootDir="$(rootDir)"
updateStatus="$rootDir/include/updateInstallStatus.sh"
LOG_PATH="/var/log/cloudron-setup.log"
WEB_PATH="/var/www/html"
HTML_PATH="/var/www/html/index.html"

start_time=$(date +%s)

# ── Download & Prepare ───────────────────────────────────────────────
echo "Downloading and installing CloudRon" | log
curlDownload https://cloudron.io/cloudron-setup
chmod u+x cloudron-setup

if [ ! -f "$LOG_PATH" ]; then
    touch "$LOG_PATH"
fi

echo "Enabling and starting cron service..." | log
sudo systemctl enable cron
sudo systemctl start cron

ubuntu_version=$(lsb_release -rs)
if [[ "$ubuntu_version" == "24.04" ]]; then
    echo "Adding shutdown cron job to root's crontab for Ubuntu 24..." | log
    CRON_JOB="@reboot ( /sbin/shutdown now; crontab -l | grep -v '@reboot /sbin/shutdown now' | crontab - )"
    (crontab -l 2>/dev/null | grep -F "$CRON_JOB") || (crontab -l 2>/dev/null; echo "$CRON_JOB") | sudo crontab -
    echo "Shutdown cron job added successfully. The system will shut down on next reboot." | log
else
    echo "This is not Ubuntu 24. Shutdown cron job will not be added." | log
fi

# ── Run CloudRon Setup ───────────────────────────────────────────────
echo "Running CloudRon setup..." | log

# Run cloudron-setup, tee to log, and process output for the landing page
"$updateStatus" "$HTML_PATH" -cp
echo Y | bash cloudron-setup 2>&1 | tee -a "$LOG_PATH" | while IFS= read -r line; do
    if [[ "$line" == *"=>"* ]]; then
        cleaned=$(echo "$line" | sed -e 's/installer://g' -e 's/start://g' -e 's/"$//' -e 's/  \+.*//' -e 's/\.*$//')
        "$updateStatus" "$HTML_PATH" -ap "${cleaned}..."
    fi
done

# ── Wait for Cloudron to actually be ready ───────────────────────────
# cloudron-setup may daemonize and return immediately,
# so we wait for the box service to be active and the dashboard to exist.
echo "Waiting for CloudRon services to be fully ready..." | log
"$updateStatus" "$HTML_PATH" -ap "Waiting for CloudRon services to initialize..."

MAX_WAIT=600  # 10 minutes
elapsed=0

while (( elapsed < MAX_WAIT )); do
    # Check if the box service is active and the dashboard exists
    if systemctl is-active --quiet box 2>/dev/null \
       && [[ -d "/home/yellowtent/box/dashboard/dist/js" ]]; then
        break
    fi
    sleep 5
    (( elapsed += 5 ))
    if (( elapsed % 30 == 0 )); then
        echo "Still waiting for CloudRon... (${elapsed}s elapsed)" | log
        "$updateStatus" "$HTML_PATH" -ap "Initializing CloudRon... (${elapsed}s)"
    fi
done

if (( elapsed >= MAX_WAIT )); then
    echo "ERROR: Timed out waiting for CloudRon services after ${MAX_WAIT}s." | log
    exit 1
fi

echo "CloudRon services are ready. (${elapsed}s)" | log

# ── DNS Placeholder Replacement ──────────────────────────────────────
echo "Cloud-Ron Directories found. Performing operations..." | log

html_target="/home/yellowtent/box/dashboard/dist/setupdns.html"
setup_target="/home/yellowtent/box/dashboard/dist/setup.html"
js_target_dir="/home/yellowtent/box/dashboard/dist/js"
js_target="${js_target_dir}/setupdns.js"

for target_file in "$setup_target" "$html_target" "$js_target"; do
    if [[ -f "$target_file" ]]; then
        sed -i "s/example.com/${CWM_DOMAIN}/g" "$target_file"
        echo "Updated: ${target_file}" | log
    else
        echo "WARN: File not found, skipping: ${target_file}" | log
    fi
done

echo "Setup DNS files have been updated." | log

# ── Touchups ─────────────────────────────────────────────────────────
bash tweaks/motd-description-append
bash tweaks/cwm-description-autoconfig

echo "Adding descriptions" | log
descriptionAppend "CloudRon Web UI: https://${CWM_DOMAIN}"
descriptionAppend "SSL will be configured after the first step."

# ── Cleanup ──────────────────────────────────────────────────────────
echo "Cleaning up..." | log
sleep 5
systemctl stop apache2
apt-get purge -y apache2 apache2-utils apache2-bin apache2.2-common
rm -rf /etc/apache2
apt-get autoremove -y
apt-get autoclean -y

end_time=$(date +%s)
duration=$((end_time - start_time))
echo "Installation completed in $duration seconds." | log

tagScript success
exit 0
