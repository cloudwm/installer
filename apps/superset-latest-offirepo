#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"

# Read admin password from guest.conf (set by cloud-init)
GUEST_CONF="/root/guest.conf"
if [ -f "${GUEST_CONF}" ]; then
    ADMINPASSWORD=$(grep -oP '(?<=^password=).+' "${GUEST_CONF}")
fi
ADMINPASSWORD="${ADMINPASSWORD:-admin}"

# ==============================
# Docker installation
# ==============================
install_docker() {
    if command -v docker >/dev/null 2>&1; then
        echo "Docker is already installed. Skipping Docker installation." | log
        return
    fi

    echo "Adding docker GPG key..." | log
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
      | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg

    echo \
      "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
      https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
      > /etc/apt/sources.list.d/docker.list

    echo "Installing Docker engine & plugins..." | log
    apt update
    apt install -y \
        docker-ce \
        docker-ce-cli \
        containerd.io \
        docker-buildx-plugin \
        docker-compose-plugin

    systemctl enable --now docker

    echo "Docker installation completed successfully." | log
}

# ==============================
# Superset
# ==============================
run_superset() {
    local TARGET_DIR="${1:-/opt/superset}"

    if ! command -v docker >/dev/null 2>&1; then
        echo "Docker is not installed" | log
        return 1
    fi

    if [ ! -d "$TARGET_DIR" ]; then
        echo "Cloning Superset repository..." | log
        git clone --depth=1 https://github.com/apache/superset.git "$TARGET_DIR" || return 1
    fi

    cd "$TARGET_DIR" || return 1

    # Configure admin credentials
    cat > docker/.env-local <<EOF
ADMIN_USERNAME=admin
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=${ADMINPASSWORD}
EOF

    # Make Superset trust the reverse proxy headers
    cat > docker/pythonpath_dev/superset_config_docker.py <<'PYEOF'
ENABLE_PROXY_FIX = True
PROXY_FIX_CONFIG = {
    "x_for": 1,
    "x_proto": 1,
    "x_host": 1,
    "x_prefix": 1,
}
PYEOF

    # Build images now, but don't start containers (installer cleanup will wipe them)
    echo "Building Superset images..." | log
    docker compose build || return 1

    # Create systemd service to start containers after boot/cleanup
    cat > /etc/systemd/system/superset.service <<EOF
[Unit]
Description=Apache Superset
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=${TARGET_DIR}
ExecStart=/usr/bin/docker compose up -d --scale nginx=0
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable superset.service
    systemctl start superset.service

    echo "Superset will start automatically after boot." | log
}

# ==============================
# Nginx reverse proxy with SSL
# ==============================
configure_nginx() {
    echo "Configuring nginx reverse proxy for Superset with SSL..." | log

    rm -f /etc/nginx/sites-enabled/default
    rm -f /etc/nginx/sites-enabled/installProgress.conf

    NGINX_CONF="/etc/nginx/sites-available/superset.conf"

    # HTTP redirect — quoted heredoc keeps $host literal
    cat > "$NGINX_CONF" <<'NGINXEOF'
server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name _;

NGINXEOF

    # SSL cert paths — unquoted heredoc for variable expansion
    cat >> "$NGINX_CONF" <<NGINXEOF
    ssl_certificate     ${LE_DIR}/fullchain.pem;
    ssl_certificate_key ${LE_DIR}/privkey.pem;
NGINXEOF

    # Rest of config — quoted heredoc keeps $host etc. literal
    cat >> "$NGINX_CONF" <<'NGINXEOF'
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=63072000" always;
    server_tokens off;

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_connect_timeout 60s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;
        proxy_buffering       off;
    }
}
NGINXEOF

    ln -sf "$NGINX_CONF" /etc/nginx/sites-enabled/superset.conf
    nginx -t || exit 1
    systemctl restart nginx

    echo "nginx configured for Superset with SSL." | log
}

# ==============================
# MOTD
# ==============================
configure_motd() {
    echo "Configuring system MOTD with Superset info..." | log

    chmod -x /etc/update-motd.d/* 2>/dev/null || true
    rm -f /etc/motd 2>/dev/null

    MACHINE_IP="$(hostname -I | awk '{print $1}')"
    SUPERSET_DIR="/opt/superset"
    DOCKER_STATUS="$(systemctl is-active docker 2>/dev/null || echo unknown)"

    if [ -f "${LE_DIR}/fullchain.pem" ]; then
        PROTO="https"
    else
        PROTO="http"
    fi

    cat > /etc/motd <<EOM
──────────────────────────────────────────────
📊  Apache Superset – Installation Complete
──────────────────────────────────────────────

    Public URL: ${PROTO}://${CWM_DOMAIN}
    Machine IP: ${MACHINE_IP}
    Domain:     ${CWM_DOMAIN}

    Admin User:     admin
    Admin Password: ${ADMINPASSWORD}

    Docker Status: ${DOCKER_STATUS}

    Install Path:  ${SUPERSET_DIR}
    Compose File:  ${SUPERSET_DIR}/docker-compose.yml
    Nginx Config:  /etc/nginx/sites-available/superset.conf

──────────────────────────────────────────────
💡  Service management:
    cd ${SUPERSET_DIR}
    docker compose ps
    docker compose logs -f
    docker compose down
    docker compose up -d

    systemctl status nginx
    systemctl reload nginx

🧹  Remove this message:
    sudo rm -f /etc/motd && sudo chmod +x /etc/update-motd.d/*
──────────────────────────────────────────────
EOM

    chmod 644 /etc/motd
    echo "Custom MOTD installed." | log
}

# ==============================
# Main
# ==============================
main() {
    install_docker
    run_superset
    configure_nginx
    configure_motd

    descriptionAppend "Superset Web UI: https://${CWM_DOMAIN}"
    descriptionAppend "Superset Admin User: admin"
    descriptionAppend "Superset Admin Password: ${ADMINPASSWORD}"

    tag Script.success
}

main
