#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
	
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi


# Update system and install required packages
apt-get update
apt-get install -y libmariadb-dev-compat apt-transport-https

# Variables
REPO_URL="https://www.redmine.org/releases/redmine-5.1.3.tar.gz"
REPO_DIR="/opt/redmine"
PUMA_SOCKET="/run/redmine/puma.sock"
PUMA_PID="/run/redmine/puma.pid"

# Secure MySQL and set up Redmine database
echo "Creating redmine database..." | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
create database redmine character set utf8mb4 collate utf8mb4_bin;
create user redmine@localhost identified by '${ADMINPASSWORD}';
grant all privileges on redmine.* to redmine@localhost;
set global log_bin_trust_function_creators = 1;
FLUSH PRIVILEGES;
EOF

# Continue with Redmine setup or other steps
echo "Database setup completed successfully." | log

# Install Redmine
echo "Creating redmine dir ${REPO_DIR}..." | log
mkdir -p ${REPO_DIR}

echo "Downloading from ${REPO_URL} to ${REPO_DIR}..." | log
curl -s ${REPO_URL} | sudo tar xz -C ${REPO_DIR} --strip-components=1
echo "Download Complete." | log

echo "Patching config/boot.rb to load stdlib Logger..." | log
BOOT_FILE="${REPO_DIR}/config/boot.rb"

if [ -f "$BOOT_FILE" ]; then
  # Prepend require 'logger' if it's not already there
  grep -q "^require 'logger'" "$BOOT_FILE" || \
    sed -i "1i require 'logger'" "$BOOT_FILE"
  echo "  → require 'logger' added to $BOOT_FILE" | log
else
  echo "  → ERROR: $BOOT_FILE not found, cannot patch Logger load" | log
  exit 1
fi

# Add puma to Gemfile.local — not in Redmine 5.1.3's default Gemfile
echo "gem 'puma'" > ${REPO_DIR}/Gemfile.local

# Configuring permissions
echo "Configuring permissions..." | log
chown -R www-data:www-data /opt/redmine/

cd ${REPO_DIR}
# Configure database connection
echo "Configure database connection..." | log
cat <<_EOF_ > ${REPO_DIR}/config/database.yml
production:
  adapter: mysql2
  database: redmine
  host: localhost
  username: redmine
  password: "${ADMINPASSWORD}"
  encoding: utf8mb4
_EOF_

# Install gems
gem install bundler
bundle config set --local without 'development test' | log
bundle install

# Prepare the database
bundle exec rake generate_secret_token
RAILS_ENV=production bundle exec rake db:migrate
RAILS_ENV=production REDMINE_LANG=en bundle exec rake redmine:load_default_data

# Install ImageMagic for Redmine
echo "Installing ImageMagic & ghostscript..." | log
apt-get update
apt-get install -y imagemagick libmagickwand-dev
convert -version
apt-get install -y ghostscript

# Configure Puma as systemd service
echo "Configuring Puma systemd service..." | log

mkdir -p /run/redmine
chown www-data:www-data /run/redmine

cat > /etc/tmpfiles.d/redmine.conf <<_EOF_
d /run/redmine 0755 www-data www-data -
_EOF_

BUNDLE_BIN=$(which bundle)

cat > /etc/systemd/system/redmine.service <<_EOF_
[Unit]
Description=Redmine (Puma)
After=network.target mysql.service
Requires=mysql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=${REPO_DIR}
Environment=RAILS_ENV=production
ExecStart=${BUNDLE_BIN} exec puma -b unix://${PUMA_SOCKET} --pidfile ${PUMA_PID} -e production
Restart=on-failure
RestartSec=5
RuntimeDirectory=redmine
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
_EOF_

systemctl daemon-reload
systemctl enable redmine
systemctl start redmine

# Wait for Puma socket
echo "Waiting for Puma to start..." | log
for i in {1..30}; do
    [ -S "${PUMA_SOCKET}" ] && break
    sleep 1
done

if [ ! -S "${PUMA_SOCKET}" ]; then
    echo "ERROR: Puma socket not created after 30s" | log
    journalctl -u redmine --no-pager -n 20
    exit 1
fi
echo "Puma is running." | log

# Configure nginx (replaces Apache)
echo "Writing nginx configuration file..." | log

LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
    SSL_CERT="${LE_DIR}/fullchain.pem"
    SSL_KEY="${LE_DIR}/privkey.pem"
    LISTEN_BLOCK="listen 443 ssl;
    ssl_certificate     ${SSL_CERT};
    ssl_certificate_key ${SSL_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;"
    REDIRECT_BLOCK="server {
    listen 80;
    server_name _;
    return 301 https://\$host\$request_uri;
}"
else
    LISTEN_BLOCK="listen 80;"
    REDIRECT_BLOCK=""
fi

rm -f /etc/nginx/sites-enabled/default
rm -f /etc/nginx/sites-enabled/installProgress.conf

cat > /etc/nginx/sites-available/redmine.conf <<_EOF_
${REDIRECT_BLOCK}

server {
    ${LISTEN_BLOCK}
    server_name _;

    client_max_body_size 100m;

    location / {
        proxy_pass http://unix:${PUMA_SOCKET};
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 300;
        proxy_connect_timeout 300;
    }
}
_EOF_

ln -sf /etc/nginx/sites-available/redmine.conf /etc/nginx/sites-enabled/redmine.conf

nginx -t
systemctl reload nginx

echo "Adding descriptions" | log
descriptionAppend "Redmine default admin user: Admin"
descriptionAppend "Redmine default admin password: admin"

echo "Redmine installation is complete."

tag Script.success