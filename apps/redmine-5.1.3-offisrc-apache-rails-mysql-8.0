#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

REDMINE_VERSION="5.1.3"
REDMINE_URL="https://www.redmine.org/releases/redmine-${REDMINE_VERSION}.tar.gz"
REDMINE_DIR="/opt/redmine"
PUMA_SOCKET="/run/redmine/puma.sock"
PUMA_PID="/run/redmine/puma.pid"

install_prereqs() {
    echo "[INFO] Installing prerequisites..." | log
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y \
        build-essential \
        ruby ruby-dev \
        libmariadb-dev-compat \
        imagemagick libmagickwand-dev \
        ghostscript \
        curl \
        ca-certificates
}

setup_database() {
    echo "[INFO] Creating Redmine database..." | log
    mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE IF NOT EXISTS redmine CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;
CREATE USER IF NOT EXISTS 'redmine'@'localhost' IDENTIFIED BY '${ADMINPASSWORD}';
GRANT ALL PRIVILEGES ON redmine.* TO 'redmine'@'localhost';
SET GLOBAL log_bin_trust_function_creators = 1;
FLUSH PRIVILEGES;
EOF
    echo "[INFO] Database setup complete." | log
}

install_redmine() {
    echo "[INFO] Downloading Redmine ${REDMINE_VERSION}..." | log
    mkdir -p "${REDMINE_DIR}"
    curl -sL "${REDMINE_URL}" | tar xz -C "${REDMINE_DIR}" --strip-components=1

    # Redmine 5.1.x on newer Ruby needs Logger loaded explicitly before bundler
    BOOT_FILE="${REDMINE_DIR}/config/boot.rb"
    if [ -f "$BOOT_FILE" ]; then
        grep -q "^require 'logger'" "$BOOT_FILE" || \
            sed -i "1i require 'logger'" "$BOOT_FILE"
        echo "[INFO] Patched config/boot.rb with require 'logger'" | log
    fi

    cat > "${REDMINE_DIR}/config/database.yml" <<DBEOF
production:
  adapter: mysql2
  database: redmine
  host: localhost
  username: redmine
  password: "${ADMINPASSWORD}"
  encoding: utf8mb4
DBEOF

    chown -R www-data:www-data "${REDMINE_DIR}"

    cd "${REDMINE_DIR}"
    gem install bundler
    bundle config set --local without 'development test'
    bundle install

    bundle exec rake generate_secret_token
    RAILS_ENV=production bundle exec rake db:migrate
    RAILS_ENV=production REDMINE_LANG=en bundle exec rake redmine:load_default_data

    chown -R www-data:www-data "${REDMINE_DIR}"
    echo "[INFO] Redmine installed." | log
}

configure_puma_service() {
    echo "[INFO] Configuring Puma systemd service..." | log

    # Runtime directory for socket and pid
    mkdir -p /run/redmine
    chown www-data:www-data /run/redmine

    cat > /etc/tmpfiles.d/redmine.conf <<EOF
d /run/redmine 0755 www-data www-data -
EOF

    cat > /etc/systemd/system/redmine.service <<EOF
[Unit]
Description=Redmine (Puma)
After=network.target mariadb.service
Requires=mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=${REDMINE_DIR}
Environment=RAILS_ENV=production
ExecStart=/usr/bin/bundle exec puma -b unix://${PUMA_SOCKET} --pidfile ${PUMA_PID} -e production
ExecStop=/bin/kill -TERM \$MAINPID
Restart=on-failure
RestartSec=5
RuntimeDirectory=redmine
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable redmine
    systemctl start redmine

    # Wait for socket
    for i in {1..30}; do
        [ -S "${PUMA_SOCKET}" ] && break
        sleep 1
    done

    if [ ! -S "${PUMA_SOCKET}" ]; then
        echo "[ERROR] Puma socket not created after 30s" | log
        journalctl -u redmine --no-pager -n 30
        exit 1
    fi

    echo "[INFO] Puma is running." | log
}

configure_nginx() {
    echo "[INFO] Configuring nginx reverse proxy..." | log

    # Detect SSL certificates from nginx-letsencrypt-cert
    LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
    if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
        SSL_CERT="${LE_DIR}/fullchain.pem"
        SSL_KEY="${LE_DIR}/privkey.pem"
        LISTEN_BLOCK="listen 443 ssl;
    ssl_certificate     ${SSL_CERT};
    ssl_certificate_key ${SSL_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;"
        REDIRECT_BLOCK="server {
    listen 80;
    server_name _;
    return 301 https://\\\$host\\\$request_uri;
}"
    else
        LISTEN_BLOCK="listen 80;"
        REDIRECT_BLOCK=""
    fi

    rm -f /etc/nginx/sites-enabled/default
    rm -f /etc/nginx/sites-enabled/installProgress.conf

    cat > /etc/nginx/sites-available/redmine.conf <<NGINXEOF
${REDIRECT_BLOCK}

server {
    ${LISTEN_BLOCK}
    server_name _;

    client_max_body_size 100m;

    location / {
        proxy_pass http://unix:${PUMA_SOCKET};
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 300;
        proxy_connect_timeout 300;
    }
}
NGINXEOF

    ln -sf /etc/nginx/sites-available/redmine.conf /etc/nginx/sites-enabled/redmine.conf

    nginx -t 2>&1 | log
    systemctl reload nginx
    echo "[INFO] nginx configured." | log
}

setup_motd() {
    echo "[INFO] Setting custom Redmine MOTD..." | log

    chmod -x /etc/update-motd.d/* 2>/dev/null || true
    rm -f /etc/motd 2>/dev/null

    MACHINE_IP=$(hostname -I | awk '{print $1}')

    if [ -f "/etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem" ]; then
        PROTO="https"
    else
        PROTO="http"
    fi

    cat > /etc/motd <<EOM
──────────────────────────────────────────────
📋  Redmine ${REDMINE_VERSION} – Installation Complete
──────────────────────────────────────────────

    Public URL: ${PROTO}://${CWM_DOMAIN}
    Machine IP: ${MACHINE_IP}
    Domain:     ${CWM_DOMAIN}

    Admin User:     admin
    Admin Password: admin
    (change on first login)

    Database User:     redmine
    Database Password: ${ADMINPASSWORD}

──────────────────────────────────────────────
💡  Service management:
    systemctl status redmine
    systemctl restart redmine
    journalctl -u redmine -f

    systemctl status nginx
    systemctl reload nginx

    Redmine directory: ${REDMINE_DIR}
    Puma socket:       ${PUMA_SOCKET}

🧹  Remove this message:
    sudo rm -f /etc/motd && sudo chmod +x /etc/update-motd.d/*
──────────────────────────────────────────────
EOM

    chmod 644 /etc/motd
    echo "[INFO] MOTD installed." | log
}

main() {
    install_prereqs
    setup_database
    install_redmine
    configure_puma_service
    configure_nginx
    setup_motd

    echo "[INFO] Redmine installation complete." | log

}

main "$@"