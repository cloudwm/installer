#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi


echo "Check if we have Docker" | log
if ! command -v docker &> /dev/null; then
    echo "Installing Docker and Docker Compose" | log
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
    sudo apt update
    sudo apt install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    sudo usermod -aG docker $USER
    sleep 5
fi

echo "Build Netbird files with domain" | log

export NETBIRD_DOMAIN="${CWM_DOMAIN}"
curl -fsSL -o getting-started.sh https://github.com/netbirdio/netbird/releases/download/v0.66.3/getting-started.sh && chmod +x getting-started.sh && sed -i 's# < /dev/tty##g' getting-started.sh && printf "2\nyes\n" | ./getting-started.sh


echo "Change path to certificate in nginx-netbird.conf" | log

sudo sed -i "s|ssl_certificate /path/to/your/fullchain.pem;|ssl_certificate /etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem;|g" nginx-netbird.conf
sudo sed -i "s|ssl_certificate_key /path/to/your/privkey.pem;|ssl_certificate_key /etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem;|g" nginx-netbird.conf

echo "Copy nginx-netbird.conf to nginx path and restart nginx" | log

cp ./nginx-netbird.conf /etc/nginx/sites-enabled/nginx-netbird.conf
systemctl restart nginx


echo "Run the service with docker compose" | log

docker compose up 
