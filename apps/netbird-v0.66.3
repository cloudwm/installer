#!/bin/bash
MAX_RETRIES=5
SLEEP_TIME=30
appDir="/opt/installer"
success=false

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi


echo "Check if we have Docker" | log
if ! command -v docker &> /dev/null; then
    echo "Installing Docker and Docker Compose" | log
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
    apt update
    apt install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    usermod -aG docker $USER
    sleep 5
fi

echo "Build Netbird files with domain" | log

export NETBIRD_DOMAIN="${CWM_DOMAIN}"
curl -fsSL -o getting-started.sh https://github.com/netbirdio/netbird/releases/download/v0.66.3/getting-started.sh && chmod +x getting-started.sh && sed -i 's# < /dev/tty##g' getting-started.sh && printf "2\nyes\n" | ./getting-started.sh


echo "Change path to certificate in nginx-netbird.conf" | log

sed -i "s|ssl_certificate /path/to/your/fullchain.pem;|ssl_certificate /etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem;|g" nginx-netbird.conf
sed -i "s|ssl_certificate_key /path/to/your/privkey.pem;|ssl_certificate_key /etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem;|g" nginx-netbird.conf

echo "Copy nginx-netbird.conf to nginx path and restart nginx" | log

cp ./nginx-netbird.conf /etc/nginx/sites-enabled/nginx-netbird.conf
systemctl restart nginx


echo "Run the service with docker compose" | log

docker compose up -d

for ((attempt=1; attempt<=MAX_RETRIES; attempt++)); do
  echo "Attempt $attempt/$MAX_RETRIES"

  all_healthy=true

  while IFS= read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    health=$(echo "$line" | sed -n 's/.*(\(.*\)).*/\1/p')

    echo "$name: ${health:-no-healthcheck}"

    if [[ "$health" != "healthy" ]]; then
      all_healthy=false
    fi
  done < <(docker ps --format '{{.Names}} {{.Status}}')

  if [[ "$all_healthy" == "true" ]]; then
    echo "Service started" | log
    success=true
    break
  fi

  if [[ $attempt -lt $MAX_RETRIES ]]; then
    echo "Some containers not healthy. Retrying in $SLEEP_TIME seconds..." | log
    sleep "$SLEEP_TIME"
  fi
done

if [[ "$success" != "true" ]]; then
  waitOrStop 0 "Service not ready"
fi


echo "Adding descriptions" | log
descriptionAppend "URL: https://${CWM_DOMAIN}"
descriptionAppend "Admin login: The administrator account registration is completed after the installation process in URL:https://${CWM_DOMAIN}."
descriptionAppend "Docker Compose: ${appDir}/docker-compose.yml"
descriptionAppend "Config file: ${appDir}/config.yaml"
descriptionAppend "Dashboard file: ${appDir}/dashboard.env"

descriptionAppend "Nginx config file /etc/nginx/sites-enabled/nginx-netbird.conf"



