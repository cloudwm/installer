#!/bin/bash
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a
export NEEDRESTART_SUSPEND=1

LOG_FILE="${CWM_LOGDIR:-/var/log}/gitlab-install.log"
mkdir -p "$(dirname "${LOG_FILE}")" 2>/dev/null || true
: >"${LOG_FILE}"

if [ -z "${CWM_DOMAIN}" ]; then
    PRIMARY_IP=$(ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if ($i=="src") print $(i+1)}' | head -n1)
    [ -z "${PRIMARY_IP}" ] && PRIMARY_IP=$(hostname -I | awk '{print $1}')
    export CWM_DOMAIN="${PRIMARY_IP//./-}.dev-cloud-xip.com"
    echo "CWM_DOMAIN was empty; derived ${CWM_DOMAIN} from ${PRIMARY_IP}" | log
fi

echo "Installing dependencies" | log
installPackage ca-certificates tzdata perl
waitOrStop 0 "Failed to install dependencies"

echo "Refreshing CA trust store" | log
apt-get install --reinstall -y ca-certificates >/dev/null 2>&1
update-ca-certificates --fresh >/dev/null 2>&1

CERT_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
if [ -f "${CERT_DIR}/fullchain.pem" ]; then
    CERT_CN=$(openssl x509 -in "${CERT_DIR}/fullchain.pem" -noout -subject 2>/dev/null | sed -n 's/.*CN *= *//p')
    if [ -z "${CERT_CN}" ]; then
        echo "Tweak-issued cert has empty CN; regenerating self-signed with CN=IL" | log
        openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
            -keyout "${CERT_DIR}/privkey.pem" \
            -out    "${CERT_DIR}/fullchain.pem" \
            -subj   "/C=IL/ST=Self-Signed/L=Self-Signed/O=Self-Signed/CN=IL" \
            2>/dev/null
    fi
fi

echo "Downloading GitLab" | log
curl -fsSL -o script.deb.sh https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.deb.sh
waitOrStop 0 "File not downloaded from official source"
bash script.deb.sh >>"${LOG_FILE}" 2>&1
waitOrStop 0 "Failed to install GitLab"
ls /etc/apt/sources.list.d/ >>"${LOG_FILE}" 2>&1

echo "Freeing ports 80/443 for GitLab's bundled nginx" | log
systemctl disable --now nginx 2>/dev/null || true

echo "Installing GitLab from apt" | log
apt update >>"${LOG_FILE}" 2>&1
EXTERNAL_URL="http://${CWM_DOMAIN}" installPackage gitlab-ce
waitOrStop 0 "Failed to install gitlab-ce"

echo "Wiring GitLab to pre-issued certificates from nginx-letsencrypt-cert tweak" | log
cat >> /etc/gitlab/gitlab.rb << EOF

# SSL — certificates provisioned by tweaks/nginx-letsencrypt-cert
external_url "https://${CWM_DOMAIN}"
letsencrypt['enable'] = false
nginx['redirect_http_to_https'] = true
nginx['ssl_certificate']     = "/etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem"
nginx['ssl_certificate_key'] = "/etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem"
EOF

echo "Reconfiguring GitLab with SSL" | log
gitlab-ctl reconfigure
waitOrStop 0 "Failed to reconfigure GitLab"

GUEST_CONF="/root/guest.conf"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
if [ -f "${GUEST_CONF}" ]; then
    ADMIN_EMAIL=$(sed -n 's/^email=//p'    "${GUEST_CONF}" | head -n1)
    ADMIN_PASSWORD=$(sed -n 's/^password=//p' "${GUEST_CONF}" | head -n1)
fi

if [ -n "${ADMIN_EMAIL}" ] && [ -n "${ADMIN_PASSWORD}" ]; then
    echo "Applying admin credentials from ${GUEST_CONF}" | log
    gitlab-rails runner - <<'RUBY' "${ADMIN_EMAIL}" "${ADMIN_PASSWORD}" >>"${LOG_FILE}" 2>&1
email, password = ARGV[0], ARGV[1]
u = User.find_by(username: 'root')
u.email = email
u.skip_reconfirmation!
u.password = password
u.password_confirmation = password
u.save!
RUBY
    waitOrStop 0 "Failed to set admin credentials"
fi

descriptionAppend "GitLab UI: https://${CWM_DOMAIN}"
descriptionAppend " "
descriptionAppend "Default admin account has been configured with following details:"
descriptionAppend "Username: root"
if [ -n "${ADMIN_EMAIL}" ] && [ -n "${ADMIN_PASSWORD}" ]; then
    descriptionAppend "Email: ${ADMIN_EMAIL}"
    descriptionAppend "Password: ${ADMIN_PASSWORD}"
else
    gitpass=$(grep Password: /etc/gitlab/initial_root_password)
    descriptionAppend "${gitpass}"
    descriptionAppend "This password will be cleaned up in first reconfigure run after 24 hours."
fi
descriptionAppend " "

tagScript success
exit 0
