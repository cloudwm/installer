#!/bin/bash
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

echo "Installing dependencies" | log
installPackage ca-certificates tzdata perl
waitOrStop 0 "Failed to install dependencies"

echo "Refreshing CA trust store" | log
apt-get install --reinstall -y ca-certificates | log
update-ca-certificates --fresh | log

echo "Downloading GitLab" | log
curl -fsSL -o script.deb.sh https://packages.gitlab.com/install/repositories/gitlab/gitlab-ce/script.deb.sh
waitOrStop 0 "File not downloaded from official source"
bash script.deb.sh | log
waitOrStop 0 "Failed to install GitLab"
ls /etc/apt/sources.list.d/ | log

echo "Freeing ports 80/443 for GitLab's bundled nginx" | log
systemctl disable --now nginx 2>/dev/null || true

echo "Installing GitLab from apt" | log
apt update
EXTERNAL_URL="http://${CWM_DOMAIN}" installPackage gitlab-ce
waitOrStop 0 "Failed to install gitlab-ce"

echo "Wiring GitLab to pre-issued certificates from nginx-letsencrypt-cert tweak" | log
cat >> /etc/gitlab/gitlab.rb << EOF

# SSL — certificates provisioned by tweaks/nginx-letsencrypt-cert
external_url "https://${CWM_DOMAIN}"
letsencrypt['enable'] = false
nginx['redirect_http_to_https'] = true
nginx['ssl_certificate']     = "/etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem"
nginx['ssl_certificate_key'] = "/etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem"
EOF

echo "Reconfiguring GitLab with SSL" | log
gitlab-ctl reconfigure
waitOrStop 0 "Failed to reconfigure GitLab"

gitpass=$(cat /etc/gitlab/initial_root_password | grep Password:)
descriptionAppend "GitLab UI: https://${CWM_DOMAIN}"
descriptionAppend " "
descriptionAppend "Default admin account has been configured with following details:"
descriptionAppend "Username: root"
descriptionAppend "${gitpass}"
descriptionAppend "This password will be cleaned up in first reconfigure run after 24 hours."
descriptionAppend " "

tagScript success
exit 0
