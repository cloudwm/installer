#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

LOG_PATH="/var/log/ollama-setup.log"
MACHINE_IP=$(hostname -I | awk '{print $1}')

[ -f "$LOG_PATH" ] || touch "$LOG_PATH"

# nginx was stopped by nginx-letsencrypt-cert (certbot standalone mode)
systemctl start nginx 2>/dev/null

echo "Opening Ollama's default port: 11434..." | log
ufw allow 11434/tcp

echo "Installing Ollama..." | log
curl -fsSL --http1.1 https://ollama.com/install.sh | sh | tee "$LOG_PATH"
INSTALL_PID=$!
wait $INSTALL_PID

# --- systemd tweak for external access ---
SERVICE_FILE="/etc/systemd/system/ollama.service"
if [ -f "$SERVICE_FILE" ] && ! grep -q '^Environment=OLLAMA_HOST=0.0.0.0:11434' "$SERVICE_FILE"; then
    sed -i '/^\[Service\]/a Environment=OLLAMA_HOST=0.0.0.0:11434' "$SERVICE_FILE"
    systemctl daemon-reload
    systemctl restart ollama
    echo "Added Environment=OLLAMA_HOST=0.0.0.0:11434 to $SERVICE_FILE and restarted service." | log
fi

systemctl daemon-reload
systemctl enable ollama.service
systemctl start ollama.service

# --- configure nginx reverse proxy for Ollama ---
switch_nginx_to_proxy() {
    echo "Configuring nginx reverse proxy for Ollama..." | log

    # Remove the install progress site so it doesn't conflict
    rm -f /etc/nginx/sites-enabled/installProgress.conf
    rm -f /etc/nginx/sites-enabled/default

    LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
    NGINX_CONF="/etc/nginx/sites-available/ollama.conf"

    if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
        echo "SSL certificates found, configuring HTTPS..." | log
        cat > "$NGINX_CONF" <<EOF
server {
    listen 80;
    server_name ${CWM_DOMAIN};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    server_name ${CWM_DOMAIN};

    ssl_certificate     ${LE_DIR}/fullchain.pem;
    ssl_certificate_key ${LE_DIR}/privkey.pem;

    location / {
        proxy_pass         http://127.0.0.1:11434;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade \$http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF
    else
        echo "No SSL certificates found, configuring HTTP only..." | log
        cat > "$NGINX_CONF" <<EOF
server {
    listen 80;
    server_name ${CWM_DOMAIN};

    location / {
        proxy_pass         http://127.0.0.1:11434;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade \$http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF
    fi

    ln -sf "$NGINX_CONF" /etc/nginx/sites-enabled/ollama.conf
    nginx -t || return 1
    systemctl reload nginx

    echo "nginx configured for Ollama." | log
}

configure_motd() {
    echo "Configuring system MOTD with Ollama info..." | log

    chmod -x /etc/update-motd.d/* 2>/dev/null || true
    rm -f /etc/motd 2>/dev/null

    LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
    if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
        SCHEME="https"
    else
        SCHEME="http"
    fi

    OLLAMA_VERSION="$(ollama --version 2>/dev/null || echo unknown)"
    OLLAMA_STATUS="$(systemctl is-active ollama 2>/dev/null || echo unknown)"
    NGINX_STATUS="$(systemctl is-active nginx 2>/dev/null || echo unknown)"

    cat > /etc/motd <<EOM
──────────────────────────────────────────────
🦙  Ollama – Installation Complete
──────────────────────────────────────────────

    Version: ${OLLAMA_VERSION}
    API URL: ${SCHEME}://${CWM_DOMAIN}
    Local API: http://127.0.0.1:11434
    Machine IP: ${MACHINE_IP}
    Domain: ${CWM_DOMAIN}

    Ollama Service: ${OLLAMA_STATUS}
    Nginx Status: ${NGINX_STATUS}

    Service File: ${SERVICE_FILE}
    Setup Log: ${LOG_PATH}

──────────────────────────────────────────────
💡  Ollama management:
    ollama list                     # list downloaded models
    ollama pull llama3              # download a model
    ollama run llama3               # run a model interactively
    ollama rm llama3                # remove a model

    sudo systemctl status ollama
    sudo systemctl restart ollama
    sudo journalctl -u ollama

🌐  API usage:
    curl ${SCHEME}://${CWM_DOMAIN}/api/tags
    curl ${SCHEME}://${CWM_DOMAIN}/api/generate -d '{
      "model": "llama3", "prompt": "Hello"
    }'

🧹  Remove this message:
    sudo rm -f /etc/motd && sudo chmod +x /etc/update-motd.d/*
──────────────────────────────────────────────
EOM

    chmod 644 /etc/motd
    echo "Custom MOTD installed at /etc/motd with Ollama details." | log
}

switch_nginx_to_proxy
configure_motd

tag Script.success