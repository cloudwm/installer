#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

appPath=/var/www/html
appVersion=5.1.1
appBranch=stable501
rootDir=$(rootDir)

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"
mkdir -p $appPath
mv moodle $appPath
rm -f moodle-$appVersion.tgz
chown -R www-data:www-data $appPath/moodle/
chmod -R 755 $appPath/moodle/

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings" | log
ini=$(find /etc -type f -name "php.ini" | grep fpm)
sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i '/max_execution_time/s/[0-9]\+/360/g' $ini
sed -i '/cgi.fix_pathinfo/s/^;//g' $ini
sed -i '/cgi.fix_pathinfo/s/[0-9]\+/0/g' $ini
sed -i 's/;max_input_vars = 1000/max_input_vars = 5000/' $ini

# Enable required PHP extensions for Moodle 5.1.1
echo "Enabling required PHP extensions" | log
phpenmod mbstring
phpenmod xml
phpenmod curl
phpenmod zip
phpenmod gd
phpenmod intl
phpenmod soap
phpenmod xmlrpc
phpenmod pdo_mysql

# Create moodledata directory
echo "Creating moodledata directory" | log
moodleDataDir="/var/moodledata"
mkdir -p $moodleDataDir
chown www-data:www-data $moodleDataDir
chmod 0777 $moodleDataDir

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    mv $appPath/phpmyadmin $appPath/moodle
fi

echo "Creating nginx configurations" | log
cp -f $rootDir/tweaks/extras/moodle-nginx/moodle.conf /etc/nginx/sites-available/
ln -s /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/
unlink /etc/nginx/sites-enabled/default
unlink /etc/nginx/sites-enabled/default-ssl
systemctl restart nginx.service
waitOrStop 0 "Restart nginx service failed"

echo "Creating minimal config.php to avoid fatal error" | log
# Create a minimal config.php that just redirects to installer
cat > $appPath/moodle/config.php << 'CONFIG'
<?php
// Minimal config.php to prevent fatal error
// This file will be replaced by Moodle installer

// Check if we're in CLI mode
if (php_sapi_name() === 'cli') {
    define('CLI_SCRIPT', true);
}

// If config.php doesn't exist yet, redirect to installer
if (!file_exists(__DIR__ . '/config.php') || filesize(__DIR__ . '/config.php') < 100) {
    if (!defined('CLI_SCRIPT') || !CLI_SCRIPT) {
        if ($_SERVER['SCRIPT_NAME'] !== '/install.php') {
            header('Location: /install.php');
            exit;
        }
    }
}

// Minimal Moodle configuration for installer
if (!isset($CFG)) {
    $CFG = new stdClass();
}

// Allow installer to run
$CFG->early_install_lang = true;
$CFG->disableupdateautodeploy = true;

// Basic settings that installer will override
$CFG->directorypermissions = 02777;

require_once(__DIR__ . '/lib/setup.php');
CONFIG

chown www-data:www-data $appPath/moodle/config.php
chmod 644 $appPath/moodle/config.php

echo "Adding descriptions" | log
descriptionAppend "Moodle 5.1.1 Web UI: https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "Moodle Username: admin"
descriptionAppend "Moodle Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "Moodle Database Name: moodle"
descriptionAppend "Moodle Database Username: moodleuser"
descriptionAppend "Moodle Database Password: ${ADMINPASSWORD}"
descriptionAppend "Moodle Data Directory: /var/moodledata"
descriptionAppend " "
descriptionAppend "Installation Steps:"
descriptionAppend "1. Visit https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "2. The installer should start automatically"
descriptionAppend "3. On 'Database settings' page use:"
descriptionAppend "   - Database type: mysqli"
descriptionAppend "   - Database host: localhost"
descriptionAppend "   - Database name: moodle"
descriptionAppend "   - Database user: moodleuser"
descriptionAppend "   - Database password: ${ADMINPASSWORD}"
descriptionAppend "   - Tables prefix: mdl_ (default)"
descriptionAppend "4. Complete the installation"
descriptionAppend " "

tagScript success

exit 0
