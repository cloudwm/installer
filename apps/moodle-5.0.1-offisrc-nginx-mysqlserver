#!/bin/bash
# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

rootDir=$(rootDir)
moodleBase=/var/www/moodle          # Base dir (outside web root, holds config.php)
moodlePublic=$moodleBase/public     # ONLY this is web-accessible
moodleData=/var/www/moodledata      # Secure data dir
appVersion=5.1.1                    # Current latest as of Dec 2025
appBranch=stable501

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"

# Clean and move to secure base location
rm -rf $moodleBase
mkdir -p $moodleBase
mv moodle/* $moodleBase/
rm -rf moodle moodle-$appVersion.tgz

# Create secure moodledata
mkdir -p $moodleData
chown -R www-data:www-data $moodleData $moodleBase
chmod 750 $moodleData
chmod -R 755 $moodleBase

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings" | log
ini=$(find /etc -type f -name "php.ini" | grep fpm)
sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i '/max_execution_time/s/[0-9]\+/360/g' $ini
sed -i '/cgi.fix_pathinfo/s/^;//g' $ini
sed -i '/cgi.fix_pathinfo/s/[0-9]\+/0/g' $ini
sed -i 's/;max_input_vars = 1000/max_input_vars = 5000/' $ini

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    mv $moodlePublic/phpmyadmin $moodlePublic/ 2>/dev/null || true
fi

echo "Creating nginx configurations" | log
cp -f $rootDir/tweaks/extras/moodle-nginx/moodle.conf /etc/nginx/sites-available/
# CRITICAL: Ensure your moodle.conf has: root /var/www/moodle/public;
# Also add routing for clean URLs, e.g.:
# location / { try_files $uri /r.php?$args; }
ln -sf /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/
unlink /etc/nginx/sites-enabled/default 2>/dev/null || true
unlink /etc/nginx/sites-enabled/default-ssl 2>/dev/null || true
systemctl restart nginx.service
waitOrStop 0 "Restart nginx service failed"

echo "Running Moodle CLI installation" | log
cd $moodleBase
sudo -u www-data php admin/cli/install.php \
    --non-interactive \
    --agree-license \
    --wwwroot=https://${CWM_DISPLAYED_ADDRESS} \
    --dataroot=$moodleData \
    --dbtype=mariadb \
    --dbhost=localhost \
    --dbname=moodle \
    --dbuser=moodleuser \
    --dbpass=${ADMINPASSWORD} \
    --fullname="Moodle Site" \
    --shortname="moodle" \
    --adminuser=admin \
    --adminpass=${ADMINPASSWORD} \
    --adminemail=${ADMINENAIL} \
    --lang=en

waitOrStop 0 "Moodle CLI installation failed"

# Secure permissions post-install
chown -R root:root $moodleBase
chown -R www-data:www-data $moodleBase/config.php $moodleData $moodlePublic
chmod 640 $moodleBase/config.php
chmod -R 750 $moodleData
chmod -R 755 $moodlePublic

echo "Adding descriptions" | log
descriptionAppend "Moodle Web UI: https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "Moodle Username: admin"
descriptionAppend "Moodle Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "Moodle Database Username: moodleuser"
descriptionAppend "Moodle Database Password: ${ADMINPASSWORD}"
descriptionAppend " "

tagScript success
exit 0
