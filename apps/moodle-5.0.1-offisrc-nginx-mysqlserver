#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

appPath=/var/www/html
appVersion=5.1.1
appBranch=stable501
rootDir=$(rootDir)

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"
mkdir -p $appPath
mv moodle $appPath
rm -f moodle-$appVersion.tgz
chown -R www-data:www-data $appPath/moodle/
chmod -R 755 $appPath/moodle/

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings" | log
ini=$(find /etc -type f -name "php.ini" | grep fpm)
sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i '/max_execution_time/s/[0-9]\+/360/g' $ini
sed -i '/cgi.fix_pathinfo/s/^;//g' $ini
sed -i '/cgi.fix_pathinfo/s/[0-9]\+/0/g' $ini
sed -i 's/;max_input_vars = 1000/max_input_vars = 5000/' $ini

# Enable required PHP extensions for Moodle 5.1.1
echo "Enabling required PHP extensions" | log
phpenmod mbstring
phpenmod xml
phpenmod curl
phpenmod zip
phpenmod gd
phpenmod intl
phpenmod soap
phpenmod xmlrpc
phpenmod pdo_mysql

# Create moodledata directory
echo "Creating moodledata directory" | log
moodleDataDir="/var/moodledata"
mkdir -p $moodleDataDir
chown www-data:www-data $moodleDataDir
chmod 0777 $moodleDataDir

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    mv $appPath/phpmyadmin $appPath/moodle
fi

echo "Creating nginx configurations" | log
cp -f $rootDir/tweaks/extras/moodle-nginx/moodle.conf /etc/nginx/sites-available/
ln -s /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/
unlink /etc/nginx/sites-enabled/default
unlink /etc/nginx/sites-enabled/default-ssl

# Test nginx configuration before restarting
echo "Testing nginx configuration..." | log
if nginx -t; then
    echo "Nginx configuration test passed" | log
    systemctl restart nginx.service
    waitOrStop 0 "Restart nginx service failed"
else
    echo "Nginx configuration test failed, showing error..." | log
    nginx -t 2>&1 | log
    echo "Attempting to fix common issues..." | log
    
    # Fix common issues in the moodle.conf
    if [ -f "/etc/nginx/sites-available/moodle.conf" ]; then
        # Make sure the root path is correct
        sed -i "s|root /var/www/html;|root /var/www/html/moodle;|g" /etc/nginx/sites-available/moodle.conf
        sed -i "s|root /var/www/html/moodle/;|root /var/www/html/moodle;|g" /etc/nginx/sites-available/moodle.conf
        
        # Test again
        if nginx -t; then
            echo "Fixed nginx configuration, restarting..." | log
            systemctl restart nginx.service
            waitOrStop 0 "Restart nginx service failed"
        else
            echo "Could not fix nginx configuration" | log
            exit 1
        fi
    fi
fi

echo "Creating proper config.php for Moodle installer" | log
# Create a proper config.php that satisfies Moodle's requirements but still allows installer
cat > $appPath/moodle/config.php << 'CONFIG'
<?php
// Moodle configuration file for installer
// This file contains minimal settings to allow installer to run
// The installer will create a complete config.php

unset($CFG);
global $CFG;
$CFG = new stdClass();

// REQUIRED: dataroot - Moodle 5.1.1 requires this even for installer
$CFG->dataroot = '/var/moodledata';

// Allow installer to run
$CFG->early_install_lang = true;
$CFG->disableupdateautodeploy = true;

// Directory permissions
$CFG->directorypermissions = 02777;

// Database settings (installer will override these)
$CFG->dbtype    = 'mysqli';
$CFG->dblibrary = 'native';
$CFG->dbhost    = 'localhost';
$CFG->dbname    = 'moodle';
$CFG->dbuser    = 'moodleuser';
$CFG->dbpass    = 'ADMINPASSWORD_PLACEHOLDER';
$CFG->prefix    = 'mdl_';
$CFG->dboptions = array(
  'dbpersist' => 0,
  'dbport' => '',
  'dbsocket' => '',
  'dbcollation' => 'utf8mb4_general_ci',
);

// wwwroot - will be detected by installer but we set it anyway
$CFG->wwwroot = 'https://CWM_DOMAIN_PLACEHOLDER';

// Force admin to be created by installer
$CFG->admin = 'admin';

// Required for setup.php
require_once(__DIR__ . '/lib/setup.php');

// If we reach here and installer hasn't run yet, redirect to installer
// but only if we're not already on the installer page
if (!defined('MOODLE_INTERNAL') && php_sapi_name() !== 'cli') {
    $current_page = $_SERVER['SCRIPT_NAME'];
    if ($current_page !== '/install.php' && $current_page !== '/admin/index.php') {
        header('Location: /install.php');
        exit;
    }
}
CONFIG

# Replace placeholders in config.php
sed -i "s|ADMINPASSWORD_PLACEHOLDER|${ADMINPASSWORD}|g" $appPath/moodle/config.php
sed -i "s|CWM_DOMAIN_PLACEHOLDER|${CWM_DISPLAYED_ADDRESS}|g" $appPath/moodle/config.php

chown www-data:www-data $appPath/moodle/config.php
chmod 644 $appPath/moodle/config.php

echo "Setting final permissions for installer" | log
# Make sure installer can write to config.php
chmod 664 $appPath/moodle/config.php

echo "Adding descriptions" | log
descriptionAppend "Moodle 5.1.1 Web UI: https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "Moodle Username: admin"
descriptionAppend "Moodle Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "Moodle Database Name: moodle"
descriptionAppend "Moodle Database Username: moodleuser"
descriptionAppend "Moodle Database Password: ${ADMINPASSWORD}"
descriptionAppend "Moodle Data Directory: /var/moodledata"
descriptionAppend " "
descriptionAppend "Installation Steps:"
descriptionAppend "1. Visit https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "2. The installer should start automatically"
descriptionAppend "3. On 'Database settings' page use:"
descriptionAppend "   - Database type: mysqli (already pre-filled)"
descriptionAppend "   - Database host: localhost (already pre-filled)"
descriptionAppend "   - Database name: moodle (already pre-filled)"
descriptionAppend "   - Database user: moodleuser (already pre-filled)"
descriptionAppend "   - Database password: ${ADMINPASSWORD} (already pre-filled)"
descriptionAppend "   - Tables prefix: mdl_ (already pre-filled)"
descriptionAppend "4. Click 'Next' and complete the installation"
descriptionAppend " "
descriptionAppend "Note: Most database fields are pre-filled in the installer"
descriptionAppend " "

tagScript success

exit 0
