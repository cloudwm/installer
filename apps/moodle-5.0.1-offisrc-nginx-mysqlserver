#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

appPath=/var/www/html
appVersion=5.1.1
appBranch=stable501
rootDir=$(rootDir)

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"
mkdir -p $appPath
mv moodle $appPath
rm -f moodle-$appVersion.tgz
chown -R www-data:www-data $appPath/moodle/
chmod -R 755 $appPath/moodle/

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings for Moodle" | log
# Find the correct php.ini file
ini=$(find /etc -type f -name "php.ini" | grep fpm | head -1)
if [ -z "$ini" ]; then
    # Fallback to common location
    if [ -f "/etc/php/8.2/fpm/php.ini" ]; then
        ini="/etc/php/8.2/fpm/php.ini"
    elif [ -f "/etc/php/8.1/fpm/php.ini" ]; then
        ini="/etc/php/8.1/fpm/php.ini"
    else
        ini="/etc/php/8.0/fpm/php.ini"
    fi
fi

sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i 's/^max_execution_time = .*/max_execution_time = 360/' $ini
sed -i 's/^;cgi.fix_pathinfo=.*/cgi.fix_pathinfo=0/' $ini
sed -i 's/^;max_input_vars = .*/max_input_vars = 5000/' $ini
sed -i 's/^post_max_size = .*/post_max_size = 512M/' $ini
sed -i 's/^upload_max_filesize = .*/upload_max_filesize = 512M/' $ini
sed -i 's/^memory_limit = .*/memory_limit = 512M/' $ini

# Enable required PHP extensions for Moodle 5.1.1
echo "Enabling required PHP extensions" | log
phpenmod mbstring
phpenmod xml
phpenmod curl
phpenmod zip
phpenmod gd
phpenmod intl
phpenmod soap
phpenmod xmlrpc
phpenmod pdo_mysql

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    # phpmyadmin handling - adjust based on your actual setup
    echo "phpMyAdmin detected - skipping integration with Moodle for security" | log
fi

echo "Generating SSL certificates if they don't exist" | log
# Generate self-signed SSL certificate if it doesn't exist
if [ ! -f /etc/ssl/certs/ssl-cert-snakeoil.pem ] || [ ! -f /etc/ssl/private/ssl-cert-snakeoil.key ]; then
    echo "Creating self-signed SSL certificate..." | log
    mkdir -p /etc/ssl/certs /etc/ssl/private
    
    # Generate self-signed certificate
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
        -keyout /etc/ssl/private/ssl-cert-snakeoil.key \
        -out /etc/ssl/certs/ssl-cert-snakeoil.pem \
        -subj "/C=US/ST=State/L=City/O=Organization/CN=${CWM_DOMAIN:-localhost}"
    
    chmod 600 /etc/ssl/private/ssl-cert-snakeoil.key
    chmod 644 /etc/ssl/certs/ssl-cert-snakeoil.pem
    
    echo "Self-signed SSL certificate created" | log
else
    echo "SSL certificates already exist, skipping generation" | log
fi

echo "Creating nginx configurations" | log
# Create a simple moodle.conf for nginx
cat > /etc/nginx/sites-available/moodle.conf << 'NGINXCONF'
server {
    listen 80;
    listen [::]:80;
    server_name _;
    root /var/www/html/moodle;
    index index.php index.html index.htm;

    # Redirect to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name _;
    root /var/www/html/moodle;
    index index.php index.html index.htm;

    # SSL configuration
    ssl_certificate /etc/ssl/certs/ssl-cert-snakeoil.pem;
    ssl_certificate_key /etc/ssl/private/ssl-cert-snakeoil.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # Moodle specific settings
    client_max_body_size 512M;
    
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ [^/]\.php(/|$) {
        fastcgi_split_path_info ^(.+?\.php)(/.*)$;
        if (!-f $document_root$fastcgi_script_name) {
            return 404;
        }
        
        fastcgi_pass unix:/var/run/php/php-fpm.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTPS on;
    }

    # Deny access to .htaccess files
    location ~ /\.ht {
        deny all;
    }
    
    # Deny access to some sensitive files
    location ~ /(config.php|composer.json|composer.lock|README.md|LICENSE|phpunit.xml|.git|.github|.env|node_modules|package.json|package-lock.json|Gruntfile.js) {
        deny all;
    }
}
NGINXCONF

# Remove existing symlinks and create new ones
rm -f /etc/nginx/sites-enabled/moodle.conf
ln -sf /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/

# Remove default sites
rm -f /etc/nginx/sites-enabled/default
rm -f /etc/nginx/sites-enabled/default-ssl

# Test nginx configuration before restart
echo "Testing nginx configuration..." | log
if nginx -t; then
    echo "Nginx configuration test passed" | log
    systemctl restart php*-fpm
    systemctl restart nginx.service
    waitOrStop 0 "Restart nginx service failed"
else
    echo "Nginx configuration test failed" | log
    echo "Showing nginx error log for debugging:" | log
    tail -20 /var/log/nginx/error.log | log
    exit 1
fi

# Create moodledata directory with proper permissions
echo "Creating moodledata directory" | log
moodleDataDir="/var/moodledata"
mkdir -p $moodleDataDir
chown www-data:www-data $moodleDataDir
chmod 0777 $moodleDataDir

# Set proper permissions for Moodle
chown -R www-data:www-data $appPath/moodle/
find $appPath/moodle -type d -exec chmod 755 {} \;
find $appPath/moodle -type f -exec chmod 644 {} \;

echo "Adding descriptions" | log
descriptionAppend "✅ Moodle 5.1.1 Installation Complete"
descriptionAppend " "
descriptionAppend "🌐 Moodle Web UI: https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "   (Use HTTPS - SSL certificate is self-signed)"
descriptionAppend " "
descriptionAppend "🔑 Admin Credentials:"
descriptionAppend "   Username: admin"
descriptionAppend "   Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "🗄️ Database Information:"
descriptionAppend "   Database: moodle"
descriptionAppend "   Username: moodleuser"
descriptionAppend "   Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "📁 Data Directory: /var/moodledata"
descriptionAppend " "
descriptionAppend "🚀 Installation Steps:"
descriptionAppend "1. Visit https://${CWM_DISPLAYED_ADDRESS}"
descriptionAppend "2. Accept the self-signed certificate warning"
descriptionAppend "3. Select language and continue"
descriptionAppend "4. On 'Database settings' page use:"
descriptionAppend "   • Database type: mysqli"
descriptionAppend "   • Host: localhost"
descriptionAppend "   • Database: moodle"
descriptionAppend "   • User: moodleuser"
descriptionAppend "   • Password: ${ADMINPASSWORD}"
descriptionAppend "   • Tables prefix: mdl_ (default)"
descriptionAppend "5. Complete the web installer"
descriptionAppend " "
descriptionAppend "⚠️ Note: First visit may show security warning due to self-signed certificate"
descriptionAppend " "

tagScript success

exit 0
