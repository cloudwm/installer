#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

appPath=/var/www/html
appVersion=5.1.1
appBranch=stable501
rootDir=$(rootDir)

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"

# Move moodle to correct location
mv moodle $appPath/
rm -f moodle-$appVersion.tgz

# Set permissions
chown -R www-data:www-data $appPath/moodle/
find $appPath/moodle -type d -exec chmod 755 {} \;
find $appPath/moodle -type f -exec chmod 644 {} \;

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings" | log
ini=$(find /etc -type f -name "php.ini" | grep fpm)
sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i '/max_execution_time/s/[0-9]\+/360/g' $ini
sed -i '/cgi.fix_pathinfo/s/^;//g' $ini
sed -i '/cgi.fix_pathinfo/s/[0-9]\+/0/g' $ini
sed -i 's/;max_input_vars = 1000/max_input_vars = 5000/' $ini

# Enable required PHP extensions
echo "Enabling required PHP extensions" | log
phpenmod mbstring
phpenmod xml
phpenmod curl
phpenmod zip
phpenmod gd
phpenmod intl
phpenmod soap
phpenmod xmlrpc
phpenmod pdo_mysql

# Create moodledata directory
echo "Creating moodledata directory" | log
moodleDataDir="/var/moodledata"
mkdir -p $moodleDataDir
chown www-data:www-data $moodleDataDir
chmod 0777 $moodleDataDir

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    if [ -d "$appPath/phpmyadmin" ]; then
        mv $appPath/phpmyadmin $appPath/moodle/ 2>/dev/null || echo "Could not move phpmyadmin" | log
    fi
fi

echo "Creating nginx configuration" | log
cp -f $rootDir/tweaks/extras/moodle-nginx/moodle.conf /etc/nginx/sites-available/
ln -sf /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default
rm -f /etc/nginx/sites-enabled/default-ssl

# Test and restart nginx
echo "Testing nginx configuration..." | log
if nginx -t; then
    echo "Nginx configuration test passed" | log
    systemctl restart nginx.service
    waitOrStop 0 "Restart nginx service failed"
else
    echo "Nginx configuration test failed" | log
    nginx -t 2>&1 | log
    exit 1
fi

echo "Creating minimal config.php for Moodle installer" | log
# Create a proper config.php that satisfies Moodle requirements
cat > $appPath/moodle/config.php << 'CONFIG'
<?php  // Moodle configuration file

unset($CFG);
global $CFG;
$CFG = new stdClass();

$CFG->dbtype    = 'mysqli';
$CFG->dblibrary = 'native';
$CFG->dbhost    = 'localhost';
$CFG->dbname    = 'moodle';
$CFG->dbuser    = 'moodleuser';
$CFG->dbpass    = 'ADMINPASSWORD_PLACEHOLDER';
$CFG->prefix    = 'mdl_';
$CFG->dboptions = array(
  'dbpersist' => 0,
  'dbport' => '',
  'dbsocket' => '',
  'dbcollation' => 'utf8mb4_general_ci',
);

$CFG->wwwroot   = 'https://CWM_DOMAIN_PLACEHOLDER';
$CFG->dataroot  = '/var/moodledata';
$CFG->admin     = 'admin';

$CFG->directorypermissions = 02777;

// Disable updates during installation
$CFG->disableupdateautodeploy = true;

// Force installer to run
if (!defined('MOODLE_INTERNAL')) {
    define('ABORT_AFTER_CONFIG', true);
}

require_once(__DIR__ . '/lib/setup.php');

// No closing tag
CONFIG

# Replace placeholders
sed -i "s|ADMINPASSWORD_PLACEHOLDER|${ADMINPASSWORD}|g" $appPath/moodle/config.php
sed -i "s|CWM_DOMAIN_PLACEHOLDER|${CWM_DISPLAYED_ADDRESS}|g" $appPath/moodle/config.php

chown www-data:www-data $appPath/moodle/config.php
chmod 644 $appPath/moodle/config.php

echo "Creating installer redirect" | log
# Create a simple index.php that redirects to installer
cat > $appPath/moodle/index.php << 'INDEX'
<?php
// Temporary index.php to redirect to installer
if (!defined('MOODLE_INTERNAL')) {
    // Check if config.php exists and has valid configuration
    if (file_exists(__DIR__ . '/config.php')) {
        require_once(__DIR__ . '/config.php');
        
        // Check if installation is complete by looking for version.php
        if (!file_exists($CFG->dataroot . '/version.php')) {
            // Redirect to installer
            header('Location: ' . $CFG->wwwroot . '/install.php');
            exit;
        }
    }
    
    // If we get here, either config.php doesn't exist or installation is complete
    if (!file_exists(__DIR__ . '/config.php')) {
        die('config.php not found. Please run the Moodle installer.');
    }
}

// If MOODLE_INTERNAL is defined, include the real setup
if (defined('MOODLE_INTERNAL')) {
    require_once($CFG->dirroot . '/lib/setup.php');
    require_once($CFG->libdir . '/outputrequirementslib.php');
    
    $PAGE->set_context(context_system::instance());
    $PAGE->set_url('/');
    $PAGE->set_pagelayout('frontpage');
    
    echo $OUTPUT->header();
    echo $OUTPUT->footer();
}
INDEX

chown www-data:www-data $appPath/moodle/index.php
chmod 644 $appPath/moodle/index.php

echo "Setting proper permissions for installer" | log
# Make moodledata writable
chmod 0777 /var/moodledata

# Make config.php writable so installer can update it
chmod 664 $appPath/moodle/config.php

echo "Testing installer access" | log
# Create a test to verify installer is accessible
sleep 2
echo "Checking if installer is accessible..." | log
if curl -k -s -o /dev/null -w "%{http_code}" https://localhost/install.php | grep -q "200"; then
    echo "Installer is accessible (HTTP 200)" | log
else
    echo "Warning: Could not access installer, check manually" | log
fi

echo "Adding descriptions" | log
descriptionAppend "✅ Moodle 5.1.1 Ready for Installation"
descriptionAppend " "
descriptionAppend "🌐 Access URLs:"
descriptionAppend "   - Moodle Installer: https://${CWM_DISPLAYED_ADDRESS}/install.php"
descriptionAppend "   - Moodle Home: https://${CWM_DISPLAYED_ADDRESS}/"
descriptionAppend " "
descriptionAppend "🔑 Database Credentials (pre-configured):"
descriptionAppend "   Database: moodle"
descriptionAppend "   Username: moodleuser"
descriptionAppend "   Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "📁 Data Directory: /var/moodledata"
descriptionAppend " "
descriptionAppend "🚀 Installation Instructions:"
descriptionAppend "   1. Visit https://${CWM_DISPLAYED_ADDRESS}/install.php"
descriptionAppend "   2. The installer will detect pre-configured database settings"
descriptionAppend "   3. Click 'Next' through the installation wizard"
descriptionAppend "   4. Create admin account when prompted"
descriptionAppend " "
descriptionAppend "⚠️ Note: The installer will ask for admin email and other details."
descriptionAppend "   Database settings are already configured."
descriptionAppend " "

tagScript success

exit 0
