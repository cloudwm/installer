#!/bin/bash

# Add this at the beginning of all scripts.
if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

checkTagExist nginx.success
checkTagExist php.success
checkTagExist mysqld.success
checkTagExist nginx-enable-php-ssl.success

appPath=/var/www/html
appVersion=5.1.1
appBranch=stable501
rootDir=$(rootDir)

echo "Downloading and extracting application" | log
cd $rootDir/temp
curlDownload https://download.moodle.org/download.php/direct/$appBranch/moodle-$appVersion.tgz
waitOrStop 0 "File not downloaded from official source"
tar -xzvf moodle-$appVersion.tgz
waitOrStop 0 "Failed to extract application archive"

# Move moodle to correct location
mv moodle $appPath/
rm -f moodle-$appVersion.tgz

# Verify installation
echo "Verifying Moodle installation..." | log
echo "Moodle directory: $appPath/moodle/" | log
echo "Files in moodle directory:" | log
ls -la $appPath/moodle/ | head -10 | log

if [ ! -f "$appPath/moodle/index.php" ]; then
    echo "ERROR: index.php not found!" | log
    echo "Check if moodle was extracted correctly" | log
    exit 1
fi

# Set permissions - IMPORTANT: don't make moodle directory writable by web server
chown -R www-data:www-data $appPath/moodle/
find $appPath/moodle -type d -exec chmod 755 {} \;
find $appPath/moodle -type f -exec chmod 644 {} \;

echo "Setting database and db user" | log
mysql --defaults-file=/root/.my.cnf -h localhost <<EOF
CREATE DATABASE moodle CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER 'moodleuser'@'localhost' identified with mysql_native_password by '${ADMINPASSWORD}';
GRANT all privileges on moodle.* to moodleuser@localhost;
FLUSH PRIVILEGES;
EOF

echo "Tweaking PHP settings" | log
ini=$(find /etc -type f -name "php.ini" | grep fpm)
sed -i '/file_uploads/s/Off/On/g' $ini
sed -i '/allow_url_fopen/s/Off/On/g' $ini
sed -i '/max_execution_time/s/[0-9]\+/360/g' $ini
sed -i '/cgi.fix_pathinfo/s/^;//g' $ini
sed -i '/cgi.fix_pathinfo/s/[0-9]\+/0/g' $ini
sed -i 's/;max_input_vars = 1000/max_input_vars = 5000/' $ini

# Enable required PHP extensions for Moodle 5.1.1
echo "Enabling required PHP extensions" | log
phpenmod mbstring
phpenmod xml
phpenmod curl
phpenmod zip
phpenmod gd
phpenmod intl
phpenmod soap
phpenmod xmlrpc
phpenmod pdo_mysql

# Create moodledata directory
echo "Creating moodledata directory" | log
moodleDataDir="/var/moodledata"
mkdir -p $moodleDataDir
chown www-data:www-data $moodleDataDir
chmod 0777 $moodleDataDir

echo "Move phpmyadmin into app if available" | log
if [ -f "$rootDir/temp/phpmyadmin.success" ]; then
    if [ -d "$appPath/phpmyadmin" ]; then
        mv $appPath/phpmyadmin $appPath/moodle/ 2>/dev/null || echo "Could not move phpmyadmin" | log
    fi
fi

echo "Setting up nginx configuration" | log
# Simply copy and enable the existing moodle.conf - NO MODIFICATIONS
cp -f $rootDir/tweaks/extras/moodle-nginx/moodle.conf /etc/nginx/sites-available/
ln -sf /etc/nginx/sites-available/moodle.conf /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default
rm -f /etc/nginx/sites-enabled/default-ssl

echo "Current nginx configuration:" | log
echo "=== moodle.conf ===" | log
cat /etc/nginx/sites-available/moodle.conf | log
echo "==================" | log

# Test nginx configuration
echo "Testing nginx configuration..." | log
if nginx -t; then
    echo "Nginx configuration test passed" | log
    systemctl restart nginx.service
    waitOrStop 0 "Restart nginx service failed"
    
    # Give nginx time to start
    sleep 2
    
    # Test if we can access the site
    echo "Testing site accessibility..." | log
    if curl -k -s -o /dev/null -w "%{http_code}" https://localhost/install.php 2>/dev/null | grep -q "200\|302"; then
        echo "Site is accessible (HTTP 200/302)" | log
    else
        echo "Warning: Site might not be accessible, check manually" | log
    fi
else
    echo "Nginx configuration test failed" | log
    echo "Error details:" | log
    nginx -t 2>&1 | log
    exit 1
fi

echo "Creating diagnostic test files" | log
# Create a simple test file to verify PHP is working
cat > $appPath/moodle/diag-test.php << 'DIAG'
<?php
echo "<h1>Diagnostic Test</h1>";
echo "<p>PHP is working!</p>";
echo "<p>Server: " . $_SERVER['SERVER_SOFTWARE'] . "</p>";
echo "<p>Document Root: " . $_SERVER['DOCUMENT_ROOT'] . "</p>";
echo "<p>Request URI: " . $_SERVER['REQUEST_URI'] . "</p>";
echo "<p>Script Name: " . $_SERVER['SCRIPT_NAME'] . "</p>";
echo "<h2>Directory Listing of " . __DIR__ . ":</h2>";
echo "<ul>";
$files = scandir(__DIR__);
foreach ($files as $file) {
    if ($file != '.' && $file != '..' && !str_starts_with($file, '.')) {
        $size = is_file($file) ? filesize($file) . " bytes" : "DIR";
        echo "<li>" . htmlspecialchars($file) . " ($size)</li>";
    }
}
echo "</ul>";
DIAG

chown www-data:www-data $appPath/moodle/diag-test.php
chmod 644 $appPath/moodle/diag-test.php

echo "Adding descriptions with troubleshooting" | log
descriptionAppend "Moodle 5.1.1 Installation"
descriptionAppend " "
descriptionAppend "🌐 Access URLs:"
descriptionAppend "   - Diagnostic Test: https://${CWM_DISPLAYED_ADDRESS}/diag-test.php"
descriptionAppend "   - Moodle Installer: https://${CWM_DISPLAYED_ADDRESS}/install.php"
descriptionAppend "   - Moodle Home: https://${CWM_DISPLAYED_ADDRESS}/"
descriptionAppend " "
descriptionAppend "🔧 If you get 404 error, check:"
descriptionAppend "   1. Diagnostic page above to see document root"
descriptionAppend "   2. Nginx config: cat /etc/nginx/sites-available/moodle.conf"
descriptionAppend "   3. Directory contents: ls -la /var/www/html/moodle/"
descriptionAppend "   4. Nginx error log: tail -f /var/log/nginx/error.log"
descriptionAppend " "
descriptionAppend "🔑 Database Credentials:"
descriptionAppend "   Database: moodle"
descriptionAppend "   Username: moodleuser"
descriptionAppend "   Password: ${ADMINPASSWORD}"
descriptionAppend " "
descriptionAppend "📁 Moodle Data Directory: /var/moodledata"
descriptionAppend " "
descriptionAppend "🚀 To install Moodle:"
descriptionAppend "   1. Visit https://${CWM_DISPLAYED_ADDRESS}/install.php"
descriptionAppend "   2. Follow the installation wizard"
descriptionAppend "   3. Use the database credentials above"
descriptionAppend " "

# Clean up - remove test file after some time (optional)
echo "Test files will be available for debugging" | log
echo "Remember to delete diag-test.php after installation" | log

tagScript success

exit 0
