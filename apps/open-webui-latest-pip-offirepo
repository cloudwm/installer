#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

prepare_env() {
    echo "Opening UFW port 8080..." | log
    ufw allow 8080/tcp

    echo "Installing python3-venv and pip..." | log
    apt update
    apt install -y python3-venv python3-pip
}

create_virtualenv() {
    VENV_DIR="$HOME/open-webui-venv"
    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
    fi
    source "$VENV_DIR/bin/activate"
}

install_openwebui() {
    echo "Installing Open-WebUI..." | log
    pip install --upgrade pip
    pip install --upgrade open-webui
}

create_service() {
    SERVICE_FILE="/etc/systemd/system/open-webui.service"
    if [ ! -f "$SERVICE_FILE" ]; then
        echo "Creating systemd service at $SERVICE_FILE ..." | log
        tee "$SERVICE_FILE" > /dev/null <<EOF
[Unit]
Description=Open WebUI
After=network.target

[Service]
Type=simple
User=$USER
Group=$USER
WorkingDirectory=$HOME
ExecStart=$HOME/open-webui-venv/bin/open-webui serve --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
Environment=PATH=$HOME/open-webui-venv/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
EOF
        systemctl daemon-reload
        systemctl enable open-webui.service
    fi
}

start_service() {
    echo "Starting Open WebUI service..." | log
    systemctl restart open-webui.service
}

switch_nginx_to_proxy() {
    echo "Configuring nginx reverse proxy for Open WebUI..." | log

    # nginx was stopped by nginx-letsencrypt-cert (certbot standalone mode)
    systemctl start nginx 2>/dev/null

    rm -f /etc/nginx/sites-enabled/installProgress.conf
    rm -f /etc/nginx/sites-enabled/default

    LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
    NGINX_CONF="/etc/nginx/sites-available/open-webui.conf"

    if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
        echo "SSL certificates found, configuring HTTPS..." | log
        cat > "$NGINX_CONF" <<EOF
server {
    listen 80;
    server_name ${CWM_DOMAIN};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    server_name ${CWM_DOMAIN};

    ssl_certificate     ${LE_DIR}/fullchain.pem;
    ssl_certificate_key ${LE_DIR}/privkey.pem;

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade \$http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF
    else
        echo "No SSL certificates found, configuring HTTP only..." | log
        cat > "$NGINX_CONF" <<EOF
server {
    listen 80;
    server_name ${CWM_DOMAIN};

    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade \$http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF
    fi

    ln -sf "$NGINX_CONF" /etc/nginx/sites-enabled/open-webui.conf
    nginx -t || return 1
    systemctl reload nginx

    echo "nginx configured for Open WebUI." | log
}

health_check_and_cleanup() {
    echo "Checking if Open WebUI responds on port 8080..." | log
    MAX_WAIT=60
    START=$(date +%s)
    while true; do
        if curl -s http://localhost:8080/ >/dev/null 2>&1; then
            echo "Open WebUI is ready at https://${CWM_DOMAIN}" | log
            sleep 10
            echo "Installation complete." | log
            break
        fi

        if (( $(date +%s) - START > MAX_WAIT )); then
            echo "Timed out after ${MAX_WAIT}s. Check: journalctl -u open-webui" | log
            exit 1
        fi
        sleep 2
    done
}

configure_motd() {
    echo "Configuring system MOTD with Open WebUI info..." | log

    chmod -x /etc/update-motd.d/* 2>/dev/null || true
    rm -f /etc/motd 2>/dev/null

    LE_DIR="/etc/letsencrypt/live/${CWM_DOMAIN}"
    if [ -f "${LE_DIR}/fullchain.pem" ] && [ -f "${LE_DIR}/privkey.pem" ]; then
        SCHEME="https"
    else
        SCHEME="http"
    fi

    MACHINE_IP=$(hostname -I | awk '{print $1}')
    OPENWEBUI_STATUS="$(systemctl is-active open-webui 2>/dev/null || echo unknown)"
    NGINX_STATUS="$(systemctl is-active nginx 2>/dev/null || echo unknown)"

    cat > /etc/motd <<EOM
──────────────────────────────────────────────
🌐  Open WebUI – Installation Complete
──────────────────────────────────────────────

    Public URL: ${SCHEME}://${CWM_DOMAIN}
    Local URL: http://127.0.0.1:8080
    Machine IP: ${MACHINE_IP}
    Domain: ${CWM_DOMAIN}

    Open WebUI Service: ${OPENWEBUI_STATUS}
    Nginx Status: ${NGINX_STATUS}

    Venv: $HOME/open-webui-venv
    Service File: /etc/systemd/system/open-webui.service

──────────────────────────────────────────────
💡  Management:
    sudo systemctl status open-webui
    sudo systemctl restart open-webui
    sudo journalctl -u open-webui

🧹  Remove this message:
    sudo rm -f /etc/motd && sudo chmod +x /etc/update-motd.d/*
──────────────────────────────────────────────
EOM

    chmod 644 /etc/motd
    echo "Custom MOTD installed." | log
}

main() {
    prepare_env
    create_virtualenv
    install_openwebui
    create_service
    start_service
    switch_nginx_to_proxy
    health_check_and_cleanup
    configure_motd
    tag Script.success
}

main