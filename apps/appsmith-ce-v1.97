#!/bin/bash

if [ -f "include/startup.sh" ]; then
    . include/startup.sh
    
elif [ -f "../include/startup.sh" ]; then
    . ../include/startup.sh
fi

APPSMITH_VERSION=v1.97
appDir="/opt/installer"
MAX_RETRIES=5
SLEEP_TIME=30

echo "Installing Docker and Docker Compose" | log
if ! command -v docker &> /dev/null; then
    echo "Installing Docker and Docker Compose" | log
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null
    apt update
    apt install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
    usermod -aG docker $USER
    sleep 5
fi


echo "Create nginx config" | log

tee /etc/nginx/sites-available/appsmith > /dev/null <<EOF
server {
    listen 80;
    server_name ${CWM_DOMAIN};

    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name ${CWM_DOMAIN};

    ssl_certificate /etc/letsencrypt/live/${CWM_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${CWM_DOMAIN}/privkey.pem;

    client_max_body_size 500M;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-Host \$host;
        proxy_set_header X-Forwarded-Port \$server_port;

        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
    }
}
EOF

echo "Create Nginx service" | log
ln -s /etc/nginx/sites-available/appsmith /etc/nginx/sites-enabled/appsmith
rm -f /etc/nginx/sites-enabled/default
systemctl reload nginx
systemctl enable nginx
systemctl restart nginx
waitOrStop 0 "Nginx service not ready"


echo "Create and run Docker Compose" | log

cat <<EOF > docker-compose.yml
version: "3"

services:
  appsmith:
    image: index.docker.io/appsmith/appsmith-ce:${APPSMITH_VERSION}
    container_name: appsmith
    ports:
      - "127.0.0.1:8080:80"
      - "127.0.0.1:8443:443"
    volumes:
      - ./stacks:/appsmith-stacks
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1/ >/dev/null || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
EOF

echo "Run docker compsoe command" | log
docker compose up -d
waitOrStop 0 "Service not ready"


for ((i=1; i<=MAX_RETRIES; i++)); do
    health_status=$(docker inspect --format='{{.State.Health.Status}}' appsmith)

    if [ "$health_status" = "healthy" ]; then
        success=true
        break
    fi

    echo "Appsmith is not healthy yet (status: $health_status) (attempt $i/$MAX_RETRIES)" | log
    sleep "$SLEEP_TIME"
done

[ "$success" = true ]
waitOrStop 0


echo "Adding descriptions" | log

descriptionAppend "Succesfully installed."
descriptionAppend "Service: AppSmith"
descriptionAppend "Configuration files: ${appDir} "
descriptionAppend "URL: https://${CWM_DOMAIN}"
descriptionAppend "Admin login: The administrator account registration is completed after the installation process."
descriptionAppend "Nginx config file /etc/nginx/sites-enabled/appsmith"
